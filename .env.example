# ── Supabase ────────────────────────────────────────────────────────────────
# Required. Get these from: https://supabase.com/dashboard → your project → Settings → API

# Your Supabase project URL (e.g. https://abcdefghijkl.supabase.co)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Your Supabase anonymous/public API key
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here"

# ── Google Gemini AI ─────────────────────────────────────────────────────────
# Required for SmartInspection and AI-powered features.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# ── App URL ──────────────────────────────────────────────────────────────────
# The URL where the web app is deployed (used for password reset redirect).
# Must be listed in Supabase Dashboard → Authentication → URL Configuration → Redirect URLs.
# Example: https://trussctr.vercel.app
VITE_APP_URL="https://your-deployed-app-url.com"
APP_URL="https://your-deployed-app-url.com"
